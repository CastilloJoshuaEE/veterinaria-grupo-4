<?xml version="1.0"?>
<!DOCTYPE module PUBLIC "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN" "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    
    
    <!-- INCLUIR REGLAS GENERALES                                         -->
    
    
    <!-- Incluir el archivo de configuración general -->
    <module name="com.puppycrawl.tools.checkstyle.checks.ModuleClassLoader">
        <!-- Esta es una referencia al archivo general -->
        <property name="fileName" value="checkstyle_general.xml"/>
    </module>
    
    
    <!-- REGLAS ESPECÍFICAS PARA MÓDULO MASCOTA                          -->
    
    
    <module name="TreeWalker">
        
        
        <!-- REGLAS DE NOMBRES PARA ENTIDADES DE MASCOTA                   -->
        
        
        <!-- Nombres de atributos de Mascota: deben tener prefijo o sufijo específico -->
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" 
                value="El atributo de Mascota ''{0}'' debe usar camelCase."/>
        </module>
        
        <!-- Nombres de métodos de servicio de mascotas: deben comenzar con verbo específico -->
        <module name="MethodName">
            <property name="format" value="^(listar|buscar|obtener|crear|actualizar|eliminar|guardar|validar)[A-Z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" 
                value="El método de Mascota ''{0}'' debe comenzar con: listar, buscar, obtener, crear, actualizar, eliminar, guardar o validar."/>
        </module>
        
        
        <!-- REGLAS DE VALIDACIÓN DE CAMPOS ESPECÍFICOS DE MASCOTA        -->
        
        
        <!-- Validar que el peso de mascota se maneje correctamente -->
        <module name="Regexp">
            <property name="format" value="peso\s*=\s*null"/>
            <property name="illegalPattern" value="true"/>
            <property name="ignoreComments" value="true"/>
            <message key="regexp.exceeded" 
                value="El peso de la mascota no debe asignarse a null. Use un valor predeterminado o valide."/>
        </module>
        
        <!-- Validar que el sexo de mascota sea 'M' o 'F' -->
        <module name="Regexp">
            <property name="format" value="sexo\s*!=\s*['&quot;][MF]['&quot;]"/>
            <property name="illegalPattern" value="true"/>
            <property name="ignoreComments" value="true"/>
            <message key="regexp.exceeded" 
                value="El sexo de la mascota debe ser 'M' (Macho) o 'F' (Hembra)."/>
        </module>
        
        <!-- Validar que la fecha de nacimiento no sea futura -->
        <module name="Regexp">
            <property name="format" value="fechaNacimiento\.after\(new Date\(\)\)"/>
            <property name="illegalPattern" value="true"/>
            <property name="ignoreComments" value="true"/>
            <message key="regexp.exceeded" 
                value="La fecha de nacimiento no debe ser futura. Debe ser una fecha válida."/>
        </module>
        
        
        <!-- REGLAS PARA VALIDACIÓN DE MASCOTA                            -->
        
        
        <!-- Validar que el método validarMascota() sea llamado -->
        <module name="Regexp">
            <property name="format" value="validarMascota\s*\("/>
            <property name="illegalPattern" value="false"/>
            <property name="ignoreComments" value="true"/>
            <message key="regexp.exceeded" 
                value="Se debe llamar al método validarMascota() antes de guardar una mascota."/>
        </module>
        
        <!-- Validar que el cliente exista antes de registrar mascota -->
        <module name="Regexp">
            <property name="format" value="clienteService\.obtenerPorId"/>
            <property name="illegalPattern" value="false"/>
            <property name="ignoreComments" value="true"/>
            <message key="regexp.exceeded" 
                value="Se debe verificar que el cliente exista antes de registrar una mascota."/>
        </module>
        
        
        <!-- REGLAS DE COMPLEJIDAD PARA MÉTODOS DE MASCOTA                -->
        
        
        <!-- Complejidad ciclomática máxima: 10 -->
        <module name="CyclomaticComplexity">
            <property name="max" value="10"/>
            <message key="cyclomaticComplexity" 
                value="La complejidad ciclomática del método ''{0}'' es de {1,number,integer} (máximo 10)."/>
        </module>
        
        <!-- Número máximo de sentencias if anidadas: 3 -->
        <module name="NestedIfDepth">
            <property name="max" value="3"/>
            <message key="nested.if.depth" 
                value="Anidamiento de if demasiado profundo ({1,number,integer}). Máximo 3 niveles."/>
        </module>
        
        <!-- Número máximo de sentencias try/catch anidadas: 2 -->
        <module name="NestedTryDepth">
            <property name="max" value="2"/>
            <message key="nested.try.depth" 
                value="Anidamiento de try demasiado profundo ({1,number,integer}). Máximo 2 niveles."/>
        </module>
        
        
        <!-- REGLAS PARA MANEJO DE EXCEPCIONES EN MASCOTA                 -->
        
        
        <!-- No permitir RuntimeException genéricas en métodos de servicio -->
        <module name="Regexp">
            <property name="format" value="throw new RuntimeException"/>
            <property name="illegalPattern" value="true"/>
            <property name="ignoreComments" value="true"/>
            <message key="regexp.exceeded" 
                value="No lance RuntimeException genéricas. Use excepciones específicas (IllegalArgumentException, IllegalStateException)."/>
        </module>
        
        <!-- Exigir que se capturen SQLException correctamente -->
        <module name="Regexp">
            <property name="format" value="catch\s*\(\s*SQLException\s+e\s*\)\s*\{"/>
            <property name="illegalPattern" value="false"/>
            <property name="ignoreComments" value="true"/>
            <message key="regexp.exceeded" 
                value="SQLException debe ser capturada y manejada adecuadamente."/>
        </module>
        
        
        <!-- REGLAS DE DOCUMENTACIÓN PARA MASCOTA                         -->
        
        
        <!-- Javadoc específico para métodos de MascotaService -->
        <module name="JavadocMethod">
            <property name="scope" value="public"/>
            <property name="allowMissingParamTags" value="false"/>
            <property name="allowMissingReturnTag" value="false"/>
            <property name="tokens" value="METHOD_DEF, CTOR_DEF"/>
            <message key="javadoc.missing" 
                value="Todos los métodos públicos de Mascota deben tener Javadoc completo."/>
        </module>
        
        <!-- Javadoc para constantes de Mascota -->
        <module name="JavadocVariable">
            <property name="scope" value="public"/>
            <message key="javadoc.missing" 
                value="Falta Javadoc para la constante ''{0}''."/>
        </module>
        
        
        <!-- REGLAS DE LONGITUD ESPECÍFICAS PARA MASCOTA                   -->
        
        
        <!-- Métodos de validación no deben exceder 50 líneas -->
        <module name="MethodLength">
            <property name="max" value="50"/>
            <property name="tokens" value="METHOD_DEF"/>
            <property name="countEmpty" value="false"/>
            <message key="maxLen.method" 
                value="Los métodos de validación no deben exceder 50 líneas. Actual: {1,number,integer} líneas."/>
        </module>
        
        
        <!-- REGLAS PARA ARCHIVOS DE ENTIDADES MASCOTA                    -->
        
        
        <!-- Verificar que los archivos Mascota.java tengan @author específico -->
        <module name="Regexp">
            <property name="format" value="@author CASTILLO MEREJILDO JOSHUA JAVIER"/>
            <property name="illegalPattern" value="false"/>
            <property name="ignoreComments" value="false"/>
            <property name="fileExtensions" value="java"/>
            <message key="regexp.exceeded" 
                value="El archivo debe incluir @author CASTILLO MEREJILDO JOSHUA JAVIER."/>
        </module>
        
    </module>
    
</module>