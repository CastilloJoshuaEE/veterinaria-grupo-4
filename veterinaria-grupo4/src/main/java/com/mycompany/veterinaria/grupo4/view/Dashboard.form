      <SubComponents>
        <Component class="javax.swing.JTextPane" name="jTextPane4">
          <Properties>
            <Property name="editable" type="boolean" value="false"/>
            <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
              <Border info="null"/>
            </Property>
            <Property name="text" type="java.lang.String" value="Existimos para salvaguardar la salud y la felicidad de tus mejores amigos de cuatro patas. A trav&#xe9;s de un entorno seguro, limpio y tecnol&#xf3;gicamente avanzado, nos aseguramos de que cada  visita sea productiva y reconfortante. Protegemos a los m&#xe1;s vulnerables y celebramos la vitalidad de las mascotas sanas, acompa&#xf1;&#xe1;ndolos en cada etapa de su desarrollo."/>
            <Property name="opaque" type="boolean" value="false"/>
          </Properties>
        </Component>
      </SubComponents>
