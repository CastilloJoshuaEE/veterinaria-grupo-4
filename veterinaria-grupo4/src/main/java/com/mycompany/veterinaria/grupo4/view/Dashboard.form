      <SubComponents>
        <Component class="javax.swing.JTextPane" name="jTextPane2">
          <Properties>
            <Property name="editable" type="boolean" value="false"/>
            <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
              <Border info="null"/>
            </Property>
            <Property name="text" type="java.lang.String" value="Queremos consolidar una gran familia en torno a &lt;b&gt;Pet Town&lt;/b&gt;. Visualizamos un futuro donde nuestra plataforma y cl&#xed;nica sean sin&#xf3;nimo de vida prolongada y feliz para las mascotas. Nuestro objetivo es establecer el est&#xe1;ndar m&#xe1;s alto en medicina veterinaria, guiados permanentemente por la compasi&#xf3;n, la actualizaci&#xf3;n cient&#xed;fica constante y el v&#xed;nculo indestructible entre las personas y los animales"/>
            <Property name="opaque" type="boolean" value="false"/>
          </Properties>
        </Component>
      </SubComponents>
    </Container>
    <Container class="javax.swing.JScrollPane" name="jScrollPane3">
      <Properties>
